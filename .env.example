# Copy to apps/web/.env.local and apps/api/.env — never commit real values.

# ─── Clerk (https://dashboard.clerk.com) ───
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Web middleware (same publishable + secret as above in apps/web/.env.local)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ─── Database (local docker-compose default) ───
DATABASE_URL=postgresql+asyncpg://backstory:backstory@localhost:5433/backstory

# ─── Redis (local docker-compose default) ───
REDIS_URL=redis://localhost:6380/0

# ─── API ───
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Embeddings (default: free local model, no API key) ───
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384
# Optional paid API instead of local:
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=384

# ─── Sprint 2 Ask — LLM generation (pick one free provider) ───

# Option A — Groq (free cloud, recommended): https://console.groq.com/keys
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_...
LLM_MODEL=llama-3.1-8b-instant

# Option B — Ollama (free local, no key): https://ollama.com
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2:3b
# OLLAMA_BASE_URL=http://localhost:11434

# Option C — Gemini (free tier with AI Studio key): https://aistudio.google.com/apikey
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=AIza...
# LLM_MODEL=gemini-2.0-flash-lite

# LLM_TEMPERATURE=0.2
# LLM_MAX_OUTPUT_TOKENS=2048
# RETRIEVAL_TOP_K=12
# RETRIEVAL_MIN_RRF_SCORE=0.008

# ─── Sprint 3 interviews (transcription) ───
TRANSCRIBE_PROVIDER=groq
TRANSCRIBE_MODEL=whisper-large-v3
# MEDIA_DIR=data/interviews
# INTERVIEW_MAX_UPLOAD_BYTES=104857600
# GITHUB_TOKEN=ghp_...          # raises GitHub API rate limits for ticket import
# UPLOAD_DIR=data/uploads       # local doc storage until R2 is wired
# SENTRY_DSN=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
